const WEATHER_MAP = { '맑음':'☀️', '구름조금':'🌤️', '흐림':'☁️', '비':'🌧️', '눈':'❄️', '바람':'💨' };

// ═══════════════════════════════════════════════
// 상태
// ═══════════════════════════════════════════════
let filteredNotices = [...MOCK_NOTICES];
let currentNotice   = null;
let currentChildTab = 0;
let writingNotice   = null; // 작성 중인 알림장 데이터
let viewMode        = 'notice'; // 'notice' | 'child'

// ═══════════════════════════════════════════════
// 초기화
// ═══════════════════════════════════════════════
function init() {
  document.getElementById('topDate').textContent =
    new Date().toLocaleDateString('ko-KR',{ year:'numeric', month:'2-digit', day:'2-digit', weekday:'short' });

  // 기간 필터 기본값: 최근 7일
  const today = new Date();
  const week  = new Date(today); week.setDate(today.getDate() - 6);
  document.getElementById('filterDateTo').value   = fmtDate(today);
  document.getElementById('filterDateFrom').value = fmtDate(week);

  initClassFilter();
  renderKPI();
  applyFilters();
}

function fmtDate(d) {
  return d.toISOString().slice(0,10);
}

// 사이드바 → operation-sidebar.js 에서 처리

// ━━━ 반 필터 ━━━
function initClassFilter() {
  const sel = document.getElementById('classFilterSelect');
  sel.innerHTML = '';

  if (userRole !== 'teacher') {
    const opt = document.createElement('option');
    opt.value = ''; opt.textContent = '전체 반';
    sel.appendChild(opt);
  }

  ALL_CLASSES.forEach(cls => {
    const opt = document.createElement('option');
    opt.value = cls.id;
    opt.textContent = cls.name + ' (' + cls.age + ')';
    if (userRole === 'teacher') {
      const isAssigned = assignedClasses.some(a => a.id === cls.id);
      if (!isAssigned) { opt.disabled = true; opt.className = 'disabled-opt'; opt.textContent += ' — 비담당'; }
    }
    sel.appendChild(opt);
  });

  if (userRole === 'teacher' && assignedClasses.length > 0) {
    sel.value = assignedClasses[0].id;
  }
}

// ━━━ KPI ━━━
function renderKPI() {
  const today = fmtDate(new Date());
  const enrolledCount = Object.values(MOCK_CHILDREN_MAP).flat().length;
  const todayPublished = MOCK_NOTICES.filter(n => n.date === today && n.status === 'published')
    .reduce((sum, n) => sum + n.child_count, 0);
  const notWritten = Math.max(0, enrolledCount - todayPublished);
  const unreadComments = MOCK_NOTICES.reduce((sum, n) => sum + n.comment_count, 0);
  const allPublished = MOCK_NOTICES.filter(n => n.status === 'published');
  const totalChildren = allPublished.reduce((s, n) => s + n.child_count, 0);
  const totalRead     = allPublished.reduce((s, n) => s + n.read_count, 0);
  const readRate = totalChildren > 0 ? Math.round(totalRead / totalChildren * 100) : 0;

  document.getElementById('kpiGrid').innerHTML = `
    <div class="kpi-card">
      <div class="kpi-ico sky">📝</div>
      <div><div class="kpi-label">오늘 작성 완료</div><div class="kpi-value">${todayPublished}명</div><div class="kpi-sub">오늘 발행된 알림장 원아 수</div></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-ico red">⚠️</div>
      <div><div class="kpi-label">미작성</div><div class="kpi-value">${notWritten}명</div><div class="kpi-sub">오늘 알림장 미발행 원아</div></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-ico amber">💬</div>
      <div><div class="kpi-label">전체 댓글</div><div class="kpi-value">${unreadComments}건</div><div class="kpi-sub">전체 기간 댓글 수</div></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-ico green">👁️</div>
      <div><div class="kpi-label">평균 읽음률</div><div class="kpi-value">${readRate}%</div><div class="kpi-sub">발행 알림장 전체 기준</div></div>
    </div>
  `;
}

// ━━━ 필터 적용 ━━━
function applyFilters() {
  const classVal   = document.getElementById('classFilterSelect').value;
  const dateFrom   = document.getElementById('filterDateFrom').value;
  const dateTo     = document.getElementById('filterDateTo').value;
  const status     = document.getElementById('filterStatus').value;
  const childName  = document.getElementById('filterChild').value.trim();

  let data = [...MOCK_NOTICES];

  if (userRole === 'teacher') {
    const ids = assignedClasses.map(a => a.id);
    data = data.filter(n => ids.includes(n.class_id));
  }
  if (classVal)  data = data.filter(n => n.class_id === classVal);
  if (dateFrom)  data = data.filter(n => n.date >= dateFrom);
  if (dateTo)    data = data.filter(n => n.date <= dateTo);
  if (status)    data = data.filter(n => n.status === status);
  if (childName) data = data.filter(n => n.children.some(c => c.name.includes(childName)));

  // 날짜 내림차순
  data.sort((a, b) => b.date.localeCompare(a.date));

  filteredNotices = data;
  document.getElementById('totalCount').textContent = data.length;
  renderList();
}

function resetFilters() {
  const today = new Date();
  const week  = new Date(today); week.setDate(today.getDate() - 6);
  document.getElementById('filterDateFrom').value = fmtDate(week);
  document.getElementById('filterDateTo').value   = fmtDate(today);
  document.getElementById('filterStatus').value   = '';
  document.getElementById('filterChild').value    = '';
  applyFilters();
}

// ━━━ 보기 모드 전환 ━━━
function setViewMode(mode) {
  viewMode = mode;
  document.getElementById('vtBtn-notice').classList.toggle('active', mode === 'notice');
  document.getElementById('vtBtn-child').classList.toggle('active', mode === 'child');
  renderList();
}

// ━━━ 목록 렌더링 ━━━
function renderList() {
  const container = document.getElementById('nbList');
  if (filteredNotices.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <div class="empty-state-icon">📋</div>
        <div class="empty-state-text">알림장이 없습니다</div>
        <div class="empty-state-sub">필터 조건을 변경하거나 새 알림장을 작성해보세요.</div>
      </div>`;
    return;
  }

  if (viewMode === 'child') {
    renderChildView(container);
    return;
  }

  // 알림장 기준 보기 — 날짜별 그룹핑
  const groups = {};
  filteredNotices.forEach(n => {
    if (!groups[n.date]) groups[n.date] = [];
    groups[n.date].push(n);
  });

  const days = ['일','월','화','수','목','금','토'];
  let html = '';
  Object.keys(groups).sort((a,b) => b.localeCompare(a)).forEach(date => {
    const d = new Date(date + 'T00:00:00');
    const dayLabel = `${date} (${days[d.getDay()]})`;
    const items = groups[date];
    const cardHtml = items.map(n => renderNBCard(n)).join('');
    html += `
      <div class="date-group">
        <div class="date-group-header">
          <div class="date-group-label">📅 ${dayLabel}</div>
          <div class="date-group-meta">${items.length}건</div>
          <div class="date-group-line"></div>
        </div>
        <div class="nb-cards">${cardHtml}</div>
      </div>`;
  });
  container.innerHTML = html;
}

// ━━━ 원아별 보기 렌더링 ━━━
function renderChildView(container) {
  const groups = {};
  filteredNotices.forEach(n => {
    if (!groups[n.date]) groups[n.date] = [];
    groups[n.date].push(n);
  });

  const days = ['일','월','화','수','목','금','토'];
  let html = '';
  Object.keys(groups).sort((a,b) => b.localeCompare(a)).forEach(date => {
    const notices = groups[date];
    const d = new Date(date + 'T00:00:00');
    const dayLabel = `${date} (${days[d.getDay()]})`;
    const totalChildren = notices.reduce((s, n) => s + (MOCK_CHILDREN_MAP[n.class_id] || []).length, 0);
    const writtenChildren = notices.reduce((s, n) => s + n.children.length, 0);

    let classHtml = '';
    notices.forEach(notice => {
      const allChildren = MOCK_CHILDREN_MAP[notice.class_id] || [];
      const cards = allChildren.map(child => renderChildViewCard(child, notice, date)).join('');
      classHtml += `
        <div style="margin-bottom:16px">
          <div style="font-size:12px;font-weight:700;color:var(--text-secondary);margin-bottom:8px;display:flex;align-items:center;gap:6px">
            <span style="width:8px;height:8px;border-radius:50%;background:${notice.teacher_color};display:inline-block;flex-shrink:0"></span>
            ${notice.class_name} · ${notice.teacher_name} 교사
            <span style="margin-left:auto;font-size:11px;color:var(--text-muted);font-weight:500">${notice.children.length}/${allChildren.length}명 작성</span>
          </div>
          <div class="cv-child-cards">${cards}</div>
        </div>`;
    });

    html += `
      <div class="date-group">
        <div class="date-group-header">
          <div class="date-group-label">📅 ${dayLabel}</div>
          <div class="date-group-meta">${writtenChildren}/${totalChildren}명 작성</div>
          <div class="date-group-line"></div>
        </div>
        ${classHtml}
      </div>`;
  });
  container.innerHTML = html;
}

function renderChildViewCard(child, notice, date) {
  const childNotice = notice.children.find(c => c.id === child.id);

  if (childNotice) {
    const isDraft = notice.status === 'draft';
    const statusClass = isDraft ? 'draft' : 'done';
    const statusLabel = isDraft ? '임시저장' : '작성완료';
    const unreadCnt = childNotice.unread_comment_count || 0;
    const totalComments = childNotice.comment_count || 0;

    let commentBtn = '';
    if (totalComments > 0) {
      const btnClass = unreadCnt > 0 ? 'has-unread' : 'read-only';
      const btnLabel = unreadCnt > 0 ? `${unreadCnt}개 미읽음` : `${totalComments}개`;
      commentBtn = `<button class="comment-badge-btn ${btnClass}" onclick="event.stopPropagation();openViewPanelAtComments('${notice.id}','${child.id}')">💬 ${btnLabel}</button>`;
    }

    return `
      <div class="cv-child-card written${isDraft ? ' has-draft' : ''}" onclick="openViewPanel('${notice.id}','${child.id}')">
        ${unreadCnt > 0 ? `<div class="cv-unread-badge">${unreadCnt}</div>` : ''}
        <div class="cv-child-avatar" style="background:${child.color}">${child.name[0]}</div>
        <div class="cv-child-name">${child.name}</div>
        <span class="cv-status-chip ${statusClass}">${statusClass === 'done' ? '✓' : '✎'} ${statusLabel}</span>
        <div style="margin-top:6px;min-height:22px">${commentBtn}</div>
      </div>`;
  } else {
    return `
      <div class="cv-child-card not-written" onclick="openWritePanelForChild('${child.id}','${notice.class_id}','${date}')">
        <div class="cv-child-avatar" style="background:${child.color};opacity:0.5">${child.name[0]}</div>
        <div class="cv-child-name">${child.name}</div>
        <span class="cv-status-chip none">미작성</span>
        <div style="margin-top:6px;min-height:22px;font-size:11px;color:var(--text-muted)">+ 작성하기</div>
      </div>`;
  }
}

function renderNBCard(n) {
  const weatherIcon = WEATHER_MAP[n.weather] || '🌤️';

  const totalUnread = n.children.reduce((sum, c) => sum + (c.unread_comment_count || 0), 0);
  const childChips = n.children.map(c => {
    const unreadCnt = c.unread_comment_count || 0;
    return `<span class="child-chip ${c.is_read ? 'read' : 'unread'}" style="cursor:pointer" onclick="event.stopPropagation();openViewPanel('${n.id}','${c.id}')">
      <span class="child-chip-dot" style="background:${c.color}"></span>${c.name}
      ${unreadCnt > 0 ? `<span class="child-chip-unread-cnt">${unreadCnt}</span>` : c.comment_count > 0 ? `<span style="color:var(--accent-dark);font-weight:800;font-size:10px">💬${c.comment_count}</span>` : ''}
    </span>`;
  }).join('');

  let commentBtn;
  if (n.comment_count > 0) {
    const btnClass = totalUnread > 0 ? 'has-unread' : 'read-only';
    const btnLabel = totalUnread > 0 ? `<span class="unread-pip"></span>💬 ${totalUnread}개 미읽음` : `💬 ${n.comment_count}개`;
    commentBtn = `<button class="comment-badge-btn ${btnClass}" onclick="event.stopPropagation();openViewPanelAtComments('${n.id}',null)">${btnLabel}</button>`;
  } else {
    commentBtn = `<span class="comment-badge-btn no-comment">💬 0</span>`;
  }

  const scheduledBadge = n.is_scheduled
    ? `<span style="font-size:11px;color:var(--purple-text);background:var(--purple-bg);padding:1px 7px;border-radius:8px;font-weight:700">🕐 ${n.scheduled_at?.slice(11,16)} 예약</span>`
    : '';

  return `
    <div class="nb-card" onclick="openViewPanel('${n.id}')">
      <div class="nb-card-accent ${n.status}"></div>
      <div class="nb-card-top">
        <div class="nb-card-teacher">
          <div class="teacher-avatar" style="background:${n.teacher_color}">${n.teacher_name[0]}</div>
          <div>
            <div class="teacher-name">${n.teacher_name} 교사</div>
            <div class="teacher-class">${n.class_name}</div>
          </div>
        </div>
        <span class="nb-status-badge ${n.status}">${n.status_label}</span>
      </div>
      ${scheduledBadge}
      <div class="nb-card-weather">${weatherIcon} ${n.weather} · ${n.temperature}</div>
      <div class="nb-card-content">${n.content}</div>
      <div class="nb-children-row">${childChips}</div>
      <div class="nb-card-footer">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          <span class="nb-meta-item">🧒 ${n.child_count}명</span>
          <span class="nb-meta-item">👁️ ${n.read_count}/${n.child_count}</span>
          ${commentBtn}
          ${n.photo_count > 0 ? `<span class="nb-meta-item">🖼️ ${n.photo_count}</span>` : ''}
          ${n.has_ai ? '<span class="nb-meta-item" style="color:var(--purple-text)">✨ AI</span>' : ''}
        </div>
        <div class="nb-card-actions">
          <div class="nb-act-btn" onclick="event.stopPropagation();openWritePanelEdit('${n.id}')" title="수정">✏️</div>
          <div class="nb-act-btn" onclick="event.stopPropagation();showToast('알림장이 회수되었습니다.')" title="회수">↩️</div>
        </div>
      </div>
    </div>`;
}

// ━━━ 상세 뷰어 패널 ━━━
function openViewPanel(id, targetChildId) {
  currentNotice = MOCK_NOTICES.find(n => n.id === id);
  if (!currentNotice) return;
  if (targetChildId) {
    const idx = currentNotice.children.findIndex(c => c.id === targetChildId);
    currentChildTab = idx >= 0 ? idx : 0;
  } else {
    currentChildTab = 0;
  }
  document.getElementById('viewPanelSub').textContent = ` · ${currentNotice.date} · ${currentNotice.class_name}`;
  renderViewPanel();
  document.getElementById('panelOverlay').classList.add('show');
  document.getElementById('viewPanel').classList.add('show');
}

function openViewPanelAtComments(noticeId, childId) {
  openViewPanel(noticeId, childId);
  setTimeout(() => {
    const body = document.getElementById('viewPanelBody');
    const commentArea = body?.querySelector('.comment-area');
    if (commentArea) commentArea.scrollIntoView({ behavior: 'smooth' });
  }, 120);
}

function renderViewPanel() {
  const n = currentNotice;
  const weatherIcon = WEATHER_MAP[n.weather] || '🌤️';
  const days = ['일','월','화','수','목','금','토'];
  const d = new Date(n.date + 'T00:00:00');
  const dateFull = `${n.date} (${days[d.getDay()]})`;

  // 원아 탭
  const childTabsHtml = n.children.map((c, i) =>
    `<div class="child-tab ${i === currentChildTab ? 'active' : ''}" onclick="switchChildTab(${i})">
      <span class="child-tab-dot" style="background:${c.color}"></span>
      ${c.name}
      ${!c.is_read ? '<span class="child-tab-unread"></span>' : ''}
    </div>`
  ).join('');

  const child = n.children[currentChildTab];

  // 모킹 체크필드 데이터
  const mockChild = {
    attendance:'출석', mood:'좋음', health:'양호',
    meal_breakfast:'잘먹음', meal_lunch:'잘먹음', meal_snack_am:'잘먹음', meal_snack_pm:'조금먹음',
    nap_status:'잘잠', nap_start:'13:00', nap_end:'14:30',
    toilet_count:1, toilet_status:'정상',
    activity_indoor:['블록놀이','그림그리기'], activity_outdoor:['산책'],
    individual_memo: child.name === '김도현' ? '오늘 특히 친구들과 사이좋게 놀았어요! 칭찬해주세요.' : '',
  };

  const moodEmoji = { '매우좋음':'😄', '좋음':'😊', '보통':'😐', '나쁨':'😞', '매우나쁨':'😢' };
  const mealIcon  = { '잘먹음':'😋', '조금먹음':'🍽️', '안먹음':'🙅', '해당없음':'—' };

  const commentsHtml = child.comment_count > 0 ? `
    <div class="comment-item">
      <div class="comment-avatar" style="background:#4361EE">이</div>
      <div class="comment-bubble teacher">
        <div class="comment-meta">
          <span class="comment-author">이하늘 교사</span>
          <span class="comment-role teacher">교사</span>
          <span class="comment-time">14:30</span>
        </div>
        <div class="comment-text">오늘 정말 즐겁게 지냈어요! 👍</div>
      </div>
    </div>
    <div class="comment-item">
      <div class="comment-avatar" style="background:#10B981">김</div>
      <div class="comment-bubble">
        <div class="comment-meta">
          <span class="comment-author">김민지</span>
          <span class="comment-role parent">엄마</span>
          <span class="comment-time">18:22</span>
        </div>
        <div class="comment-text">감사합니다 선생님 😊 집에서도 오늘 이야기 잔뜩 해줬어요~</div>
        <div class="comment-actions">
          <button class="comment-reply-btn" onclick="showToast('답글 기능은 준비 중입니다.')">↩ 답글</button>
        </div>
      </div>
    </div>` : '<div style="text-align:center;padding:16px 0;font-size:13px;color:var(--text-muted)">아직 댓글이 없습니다.</div>';

  document.getElementById('viewPanelBody').innerHTML = `
    <div class="view-date-bar">
      <div>
        <div class="view-date-big">${dateFull}</div>
        <div class="view-meta-row">
          <div class="view-teacher-chip">
            <div class="teacher-avatar" style="background:${n.teacher_color};width:22px;height:22px;font-size:10px">${n.teacher_name[0]}</div>
            <span>${n.teacher_name} 교사 · ${n.class_name}</span>
          </div>
        </div>
      </div>
      <div class="view-weather-icon">${weatherIcon}</div>
    </div>

    <div class="view-section">
      <div class="view-section-title">📝 공통 본문</div>
      <div class="view-content-text">${n.content}</div>
    </div>

    <div class="child-tabs">${childTabsHtml}</div>

    <div class="view-section">
      <div class="view-section-title">📊 원아 상태 — ${child.name}</div>
      <div class="check-grid">
        <div class="check-item"><div class="check-item-label">출결</div><div class="check-item-value">✅ ${mockChild.attendance}</div></div>
        <div class="check-item"><div class="check-item-label">기분</div><div class="check-item-value">${moodEmoji[mockChild.mood]} ${mockChild.mood}</div></div>
        <div class="check-item"><div class="check-item-label">건강</div><div class="check-item-value">💚 ${mockChild.health}</div></div>
        <div class="check-item"><div class="check-item-label">낮잠</div><div class="check-item-value">😴 ${mockChild.nap_status} (${mockChild.nap_start}~${mockChild.nap_end})</div></div>
        <div class="check-item"><div class="check-item-label">배변</div><div class="check-item-value">🚽 ${mockChild.toilet_status} ${mockChild.toilet_count}회</div></div>
        <div class="check-item"><div class="check-item-label">읽음</div><div class="check-item-value">${child.is_read ? '✅ 읽음' : '⏳ 미읽음'}</div></div>
      </div>
      <div class="view-section-title" style="margin-top:12px">🍽️ 식사</div>
      <div class="meal-row">
        <div class="meal-cell"><div class="meal-cell-label">아침</div><div class="meal-cell-value">${mealIcon[mockChild.meal_breakfast]} ${mockChild.meal_breakfast}</div></div>
        <div class="meal-cell"><div class="meal-cell-label">점심</div><div class="meal-cell-value">${mealIcon[mockChild.meal_lunch]} ${mockChild.meal_lunch}</div></div>
        <div class="meal-cell"><div class="meal-cell-label">오전간식</div><div class="meal-cell-value">${mealIcon[mockChild.meal_snack_am]} ${mockChild.meal_snack_am}</div></div>
        <div class="meal-cell"><div class="meal-cell-label">오후간식</div><div class="meal-cell-value">${mealIcon[mockChild.meal_snack_pm]} ${mockChild.meal_snack_pm}</div></div>
      </div>
      <div class="view-section-title" style="margin-top:12px">🎯 활동</div>
      <div class="activity-tags">
        ${mockChild.activity_indoor.map(t => `<span class="act-tag">${t}</span>`).join('')}
        ${mockChild.activity_outdoor.map(t => `<span class="act-tag outdoor">${t}</span>`).join('')}
      </div>
      ${mockChild.individual_memo ? `<div style="margin-top:12px;padding:10px 12px;background:var(--amber-bg);border-radius:var(--r-md);font-size:13px;color:var(--amber-text)">📌 ${mockChild.individual_memo}</div>` : ''}
    </div>

    ${n.photo_count > 0 ? `
    <div class="view-section">
      <div class="view-section-title">🖼️ 사진 (${n.photo_count}장)</div>
      <div class="photo-grid">
        ${Array.from({length:n.photo_count}, (_,i) => `<div class="photo-thumb">📷</div>`).join('')}
      </div>
    </div>` : ''}

    <div class="comment-area">
      <div class="view-section-title" style="padding:0 0 10px">💬 댓글 (${child.comment_count})</div>
      <div class="comment-list">${commentsHtml}</div>
      <div class="comment-input-wrap">
        <textarea class="comment-input" placeholder="댓글을 입력하세요..." rows="1"></textarea>
        <button class="comment-send-btn" onclick="showToast('댓글이 등록되었습니다.')">전송</button>
      </div>
    </div>
  `;
}

function switchChildTab(idx) {
  currentChildTab = idx;
  renderViewPanel();
}

function closeViewPanel() {
  document.getElementById('viewPanel').classList.remove('show');
  document.getElementById('panelOverlay').classList.remove('show');
}

function openWritePanelFromView() {
  closeViewPanel();
  if (currentNotice) openWritePanelEdit(currentNotice.id);
}

// ━━━ 작성 패널 ━━━
function openWritePanel(preClassId, preDate, preChildId) {
  writingNotice = null;
  document.getElementById('writePanelTitle').textContent = '✏️ 알림장 작성';
  renderWritePanel(null, preClassId, preDate, preChildId);
  document.getElementById('panelOverlay').classList.add('show');
  document.getElementById('writePanel').classList.add('show');
}

function openWritePanelForChild(childId, classId, date) {
  const existing = MOCK_NOTICES.find(n => n.class_id === classId && n.date === date && n.status === 'draft');
  if (existing) {
    openWritePanelEdit(existing.id);
  } else {
    openWritePanel(classId, date, childId);
  }
}

function openWritePanelEdit(id) {
  writingNotice = MOCK_NOTICES.find(n => n.id === id) || null;
  document.getElementById('writePanelTitle').textContent = '✏️ 알림장 수정';
  renderWritePanel(writingNotice);
  document.getElementById('panelOverlay').classList.add('show');
  document.getElementById('writePanel').classList.add('show');
}

function renderWritePanel(notice, preClassId, preDate, preChildId) {
  const activeClassId = notice?.class_id || preClassId;
  const classOpts = ALL_CLASSES.map(c =>
    `<option value="${c.id}" ${activeClassId === c.id ? 'selected' : ''}>${c.name}</option>`
  ).join('');

  const selectedClass = notice
    ? ALL_CLASSES.find(c => c.id === notice.class_id)
    : (preClassId ? ALL_CLASSES.find(c => c.id === preClassId) : ALL_CLASSES[0]);
  const children = MOCK_CHILDREN_MAP[selectedClass?.id || 'CLS001'] || [];

  const childCards = children.map(c => {
    const ATTENDANCE = ['출석','결석','조퇴','지각','외출'];
    const MOODS      = ['매우좋음','좋음','보통','나쁨','매우나쁨'];
    const MEALS      = ['잘먹음','조금먹음','안먹음','해당없음'];
    const NAPS       = ['잘잠','조금잠','못잠','안잠'];
    const INDOOR_TAGS = ['블록놀이','그림그리기','색칠하기','독서','퍼즐','역할놀이','율동','점토놀이'];
    const OUTDOOR_TAGS = ['모래놀이','산책','자전거','공놀이','줄넘기','텃밭가꾸기'];

    return `
    <div class="write-child-card">
      <div class="wcc-header">
        <div class="wcc-avatar" style="background:${c.color}">${c.name[0]}</div>
        <div class="wcc-name">${c.name}</div>
      </div>
      <div class="wcc-body">
        <div>
          <div class="wcc-field-label">출결 *</div>
          <div class="check-btn-group">
            ${ATTENDANCE.map((a,i) => `<button class="check-btn ${i===0?'active green':''}" onclick="toggleCheckBtn(this,'att-${c.id}')">${a}</button>`).join('')}
          </div>
        </div>
        <div>
          <div class="wcc-field-label">기분</div>
          <div class="check-btn-group">
            ${MOODS.map((m,i) => `<button class="check-btn ${i===1?'active':''}" onclick="toggleCheckBtn(this,'mood-${c.id}')">${m}</button>`).join('')}
          </div>
        </div>
        <div>
          <div class="wcc-field-label">점심</div>
          <div class="check-btn-group">
            ${MEALS.map((m,i) => `<button class="check-btn ${i===0?'active':''}" onclick="toggleCheckBtn(this,'meal-${c.id}')">${m}</button>`).join('')}
          </div>
        </div>
        <div>
          <div class="wcc-field-label">낮잠</div>
          <div class="check-btn-group">
            ${NAPS.map((n,i) => `<button class="check-btn ${i===0?'active':''}" onclick="toggleCheckBtn(this,'nap-${c.id}')">${n}</button>`).join('')}
          </div>
          <div class="nap-time-row">
            <input class="nap-time-input" type="time" value="13:00">
            <span class="nap-time-sep">~</span>
            <input class="nap-time-input" type="time" value="14:30">
          </div>
        </div>
        <div>
          <div class="wcc-field-label">실내활동</div>
          <div class="tag-select-wrap">
            ${INDOOR_TAGS.map(t => `<button class="tag-btn" onclick="this.classList.toggle('active')">${t}</button>`).join('')}
          </div>
        </div>
        <div>
          <div class="wcc-field-label">실외활동</div>
          <div class="tag-select-wrap">
            ${OUTDOOR_TAGS.map(t => `<button class="tag-btn outdoor" onclick="this.classList.toggle('active outdoor')">${t}</button>`).join('')}
          </div>
        </div>
        <div>
          <div class="wcc-field-label">개별 메모</div>
          <textarea class="form-textarea" style="min-height:60px" placeholder="${c.name}에게 전달할 개별 내용을 입력하세요..."></textarea>
        </div>
      </div>
    </div>`;
  }).join('');

  const WEATHER_LIST = ['맑음','구름조금','흐림','비','눈','바람'];

  document.getElementById('writePanelBody').innerHTML = `
    <!-- 기본설정 -->
    <div class="write-section">
      <div class="write-section-title"><span class="ws-icon">⚙️</span> 기본 설정</div>
      <div class="form-row col3">
        <div class="form-group">
          <div class="form-label">날짜 <span class="req">*</span></div>
          <input class="form-input" type="date" id="writeDate" value="${notice?.date || preDate || fmtDate(new Date())}">
        </div>
        <div class="form-group">
          <div class="form-label">반 선택 <span class="req">*</span></div>
          <select class="form-select" id="writeClass">${classOpts}</select>
        </div>
        <div class="form-group">
          <div class="form-label">기온</div>
          <input class="form-input" type="text" id="writeTemp" placeholder="예: 16°C / 8°C" value="${notice?.temperature || ''}">
        </div>
      </div>
      <div class="form-group" style="margin-top:4px">
        <div class="form-label">날씨</div>
        <div class="weather-btn-group" id="weatherBtnGroup">
          ${WEATHER_LIST.map(w => `<button class="weather-btn ${notice?.weather === w ? 'active' : ''}" onclick="selectWeather(this,'${w}')">${WEATHER_MAP[w]} ${w}</button>`).join('')}
        </div>
      </div>
    </div>

    <!-- 공통 본문 -->
    <div class="write-section">
      <div class="write-section-title"><span class="ws-icon">📝</span> 공통 본문</div>
      <div class="form-row full">
        <textarea class="form-textarea" id="writeContent" style="min-height:120px" placeholder="오늘 반 전체에 전달할 내용을 입력하세요...">${notice?.content || ''}</textarea>
      </div>
      <div class="ai-toolbar">
        <button class="ai-btn generate" onclick="simulateAI()">✨ AI 자동생성</button>
        <button class="ai-btn polish" onclick="simulatePolish()">🪄 문장 다듬기</button>
        <button class="ai-btn template" onclick="openTemplateModal()">📚 예문 불러오기</button>
      </div>
    </div>

    <!-- 대상 원아 -->
    <div class="write-section">
      <div class="write-section-title"><span class="ws-icon">🧒</span> 대상 원아 선택</div>
      <div class="child-select-grid" id="childSelectGrid">
        ${children.map((c,i) => {
          const isSelected = preChildId ? (c.id === preChildId) : true;
          return `<div class="child-select-card ${isSelected ? 'selected' : ''}" onclick="this.classList.toggle('selected')">
            <div class="csc-avatar" style="background:${c.color}">${c.name[0]}</div>
            <div class="csc-name">${c.name}</div>
            <div class="csc-check">✓</div>
          </div>`;
        }).join('')}
      </div>
    </div>

    <!-- 원아별 체크필드 -->
    <div class="write-section">
      <div class="write-section-title"><span class="ws-icon">📊</span> 원아별 상태 입력</div>
    </div>
    <div class="write-child-grid">${childCards}</div>
  `;
}

function toggleCheckBtn(btn, group) {
  btn.closest('.check-btn-group').querySelectorAll('.check-btn').forEach(b => {
    b.classList.remove('active','green','red','amber');
  });
  btn.classList.add('active');
}

function selectWeather(btn) {
  document.getElementById('weatherBtnGroup').querySelectorAll('.weather-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function closeWritePanel() {
  document.getElementById('writePanel').classList.remove('show');
  document.getElementById('panelOverlay').classList.remove('show');
}

function saveDraft() {
  showToast('임시저장되었습니다.', 'success');
}

function submitPublish() {
  showToast('알림장이 발행되었습니다! 📤', 'success');
  closeWritePanel();
  applyFilters();
}

// ━━━ AI 모의 기능 ━━━
function simulateAI() {
  const ta = document.getElementById('writeContent');
  ta.value = '';
  const text = '오늘은 맑고 따뜻한 날씨 속에 아이들과 즐거운 하루를 보냈습니다. 오전에는 블록 놀이와 그림 그리기 활동을 하며 창의력을 키웠고, 오후에는 텃밭 관찰 활동으로 봄을 느꼈습니다. 점심도 맛있게 먹고 낮잠도 잘 잤어요.';
  let i = 0;
  showToast('✨ AI가 본문을 생성하고 있습니다...', 'ai');
  const interval = setInterval(() => {
    ta.value += text[i++];
    if (i >= text.length) clearInterval(interval);
  }, 25);
}

function simulatePolish() {
  showToast('🪄 문장이 다듬어졌습니다.', 'ai');
}

// ━━━ 예문 라이브러리 모달 ━━━
function openTemplateModal() {
  renderTemplateList();
  document.getElementById('templateModal').classList.add('show');
}

function closeTemplateModal() {
  document.getElementById('templateModal').classList.remove('show');
}

function renderTemplateList() {
  const cat    = document.getElementById('tmplCategoryFilter').value;
  const search = document.getElementById('tmplSearch').value.trim().toLowerCase();
  let list = [...MOCK_TEMPLATES];
  if (cat)    list = list.filter(t => t.category === cat);
  if (search) list = list.filter(t => t.title.toLowerCase().includes(search) || t.content.toLowerCase().includes(search));
  list.sort((a,b) => b.use_count - a.use_count);

  if (list.length === 0) {
    document.getElementById('templateList').innerHTML = '<div style="text-align:center;padding:24px;color:var(--text-muted);font-size:13px">검색 결과가 없습니다.</div>';
    return;
  }
  document.getElementById('templateList').innerHTML = list.map(t => `
    <div class="template-card" onclick="useTemplate('${t.id}')">
      <div class="template-card-title">
        ${t.title}
        <span class="template-tag">${t.category}</span>
        ${t.is_ai_generated ? '<span class="template-tag ai">✨ AI</span>' : ''}
      </div>
      <div class="template-card-preview">${t.content}</div>
      <div class="template-card-meta">
        <span class="template-use-cnt">사용 ${t.use_count}회</span>
      </div>
    </div>`).join('');
}

function useTemplate(id) {
  const t = MOCK_TEMPLATES.find(t => t.id === id);
  if (!t) return;
  const ta = document.getElementById('writeContent');
  if (ta) ta.value = t.content;
  closeTemplateModal();
  showToast(`"${t.title}" 예문을 불러왔습니다.`, 'success');
}

function openNewTemplateForm() {
  showToast('예문 직접 추가 기능은 준비 중입니다.');
  closeTemplateModal();
}

// ━━━ 예약 발행 모달 ━━━
function openScheduleModal() {
  document.getElementById('scheduleDate').value = '';
  document.getElementById('scheduleTime').value = '';
  document.getElementById('scheduleModal').classList.add('show');
}

function closeScheduleModal() {
  document.getElementById('scheduleModal').classList.remove('show');
}

function submitSchedule() {
  const date = document.getElementById('scheduleDate').value;
  const time = document.getElementById('scheduleTime').value;
  if (!date || !time) { showToast('날짜와 시간을 모두 입력해주세요.', 'error'); return; }
  closeScheduleModal();
  showToast(`${date} ${time} 예약 발행이 설정되었습니다.`, 'success');
  closeWritePanel();
}

// ━━━ 공통 ━━━
function closePanels() {
  document.getElementById('viewPanel').classList.remove('show');
  document.getElementById('writePanel').classList.remove('show');
  document.getElementById('panelOverlay').classList.remove('show');
}

// changeOrg / exitContext / logout → operation-sidebar.js 에서 전역 노출

function showToast(msg, type = '') {
  const wrap = document.getElementById('toastWrap');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  wrap.appendChild(el);
  setTimeout(() => el.remove(), 3000);
}

// ━━━ 실행 ━━━
init();
</script>
</body>
</html>