/* ═══════════════════════════════════════════════
   4. 초기화
═══════════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
  initTopbar();
  initClassFilter();
  initDateFilters();
  renderKpi();
  applyFilters();
  document.addEventListener('keydown', e => { if(e.key==='Escape') closePanels(); });
});

function initTopbar() {
  document.getElementById('topDate').textContent = new Date().toLocaleDateString('ko-KR',{year:'numeric',month:'long',day:'numeric',weekday:'short'});
  document.getElementById('breadcrumbOrg').textContent = CURRENT_ORG.orgName || '운영관리';
}

function initClassFilter() {
  const sel = document.getElementById('classFilterSelect');
  const classes = IS_TEACHER ? CLASSES.filter(c=> (SESSION.assignedClasses||[]).some(a=>a.id===c.id)) : CLASSES;
  const opts = IS_TEACHER ? '' : '<option value="">전체 반</option>';
  sel.innerHTML = opts + classes.map(c=>`<option value="${c.id}">${c.name} (${c.age})</option>`).join('');
  if(IS_TEACHER && classes.length>0) { selectedClassId = classes[0].id; sel.value = selectedClassId; }
  sel.onchange = () => { selectedClassId = sel.value; applyFilters(); };
}

function initDateFilters() {
  const today = new Date();
  const sevenAgo = new Date(today); sevenAgo.setDate(today.getDate()-7);
  document.getElementById('filterDateFrom').value = sevenAgo.toISOString().slice(0,10);
  document.getElementById('filterDateTo').value   = today.toISOString().slice(0,10);
}

/* ═══════════════════════════════════════════════
   5. KPI
═══════════════════════════════════════════════ */
function renderKpi() {
  const today = new Date().toISOString().slice(0,10);
  const todayNotices = allNotices.filter(n=>n.date===today && n.status==='published');
  const todayChildCount = todayNotices.reduce((s,n)=>s+n.childCount,0);
  const totalEnrolled = CHILDREN.filter(c=> !selectedClassId || c.classId===selectedClassId).length;
  const unwritten = Math.max(0, totalEnrolled - todayChildCount);
  const unreadComments = allNotices.reduce((s,n)=>s+n.children.reduce((cs,c)=>cs+c.comments.filter(cm=>cm.authorType==='parent').length,0),0);
  const readRatio = (() => {
    const pub = allNotices.filter(n=>n.status==='published');
    const total = pub.reduce((s,n)=>s+n.childCount,0);
    const read  = pub.reduce((s,n)=>s+n.readCount,0);
    return total>0 ? Math.round(read/total*100) : 0;
  })();
  document.getElementById('kpiGrid').innerHTML = `
    <div class="kpi-card"><div class="kpi-ico sky">📋</div><div><div class="kpi-label">오늘 작성 완료</div><div class="kpi-value">${todayChildCount}</div><div class="kpi-sub">명의 원아</div></div></div>
    <div class="kpi-card"><div class="kpi-ico red">⚠️</div><div><div class="kpi-label">미작성</div><div class="kpi-value">${unwritten}</div><div class="kpi-sub">명 미기록</div></div></div>
    <div class="kpi-card"><div class="kpi-ico amber">💬</div><div><div class="kpi-label">미읽음 댓글</div><div class="kpi-value">${unreadComments}</div><div class="kpi-sub">학부모 댓글</div></div></div>
    <div class="kpi-card"><div class="kpi-ico green">👀</div><div><div class="kpi-label">평균 읽음률</div><div class="kpi-value">${readRatio}%</div><div class="kpi-sub">전체 발행 기준</div></div></div>
  `;
}

/* ═══════════════════════════════════════════════
   6. 목록 필터 & 렌더
═══════════════════════════════════════════════ */
function applyFilters() {
  selectedClassId = document.getElementById('classFilterSelect').value;
  const dateFrom = document.getElementById('filterDateFrom').value;
  const dateTo   = document.getElementById('filterDateTo').value;
  const status   = document.getElementById('filterStatus').value;
  const childKw  = document.getElementById('filterChild').value.trim();

  filteredNotices = allNotices.filter(n => {
    if(selectedClassId && n.classId !== selectedClassId) return false;
    if(dateFrom && n.date < dateFrom) return false;
    if(dateTo   && n.date > dateTo)   return false;
    if(status   && n.status !== status) return false;
    if(childKw  && !n.children.some(c=>c.childName.includes(childKw))) return false;
    return true;
  });

  filteredNotices.sort((a,b)=>b.date.localeCompare(a.date));
  document.getElementById('totalCount').textContent = filteredNotices.length;
  renderList();
  renderKpi();
}

function resetFilters() {
  document.getElementById('filterStatus').value = '';
  document.getElementById('filterChild').value  = '';
  initDateFilters();
  applyFilters();
}

function renderList() {
  const container = document.getElementById('nbList');
  if(!filteredNotices.length) {
    container.innerHTML = `<div class="empty-state"><div class="empty-state-icon">📋</div><div class="empty-state-text">알림장이 없습니다</div><div class="empty-state-sub">조건에 맞는 알림장이 없어요. 필터를 변경하거나 새 알림장을 작성해보세요.</div></div>`;
    return;
  }

  const groups = {};
  filteredNotices.forEach(n => { if(!groups[n.date]) groups[n.date] = []; groups[n.date].push(n); });
  const sortedDates = Object.keys(groups).sort((a,b)=>b.localeCompare(a));

  container.innerHTML = sortedDates.map(date => {
    const dateObj = new Date(date+'T00:00:00');
    const dayStr = ['일','월','화','수','목','금','토'][dateObj.getDay()];
    const dateLabel = `${date.replace(/-/g,'.')} (${dayStr})`;
    const cards = groups[date].map(n => renderCard(n)).join('');
    return `
      <div class="date-group">
        <div class="date-group-header">
          <span class="date-group-label">${dateLabel}</span>
          <span class="date-group-meta">${groups[date].length}건</span>
          <div class="date-group-line"></div>
        </div>
        <div class="nb-cards">${cards}</div>
      </div>`;
  }).join('');
}

function renderCard(n) {
  const statusMap = { published:['발행됨','published'], draft:['임시저장','draft'], recalled:['회수됨','recalled'], scheduled:['예약발행','scheduled'] };
  const [sLabel, sCls] = statusMap[n.status] || ['알 수 없음','draft'];
  const childChips = n.children.map(c=>`<span class="child-chip ${c.isRead?'read':'unread'}"><span class="child-chip-dot" style="background:${c.color}"></span>${c.childName} ${ATTENDANCE_COLOR[c.attendance]?`<span style="font-size:9px;color:${ATTENDANCE_COLOR[c.attendance]}">${c.attendance}</span>`:''}</span>`).join('');
  const preview = n.content.slice(0,60) + (n.content.length>60?'…':'');
  const weatherLabel = n.weather ? `${WEATHER_EMOJI[n.weather]||''} ${n.weather} · ${n.temperature}` : '';
  const timeLabel = n.isScheduled ? `🕐 ${n.scheduledAt} 예약` : (n.publishedAt ? n.publishedAt.slice(11,16)+' 발행' : '');
  return `
    <div class="nb-card" onclick="openViewPanel('${n.id}')">
      <div class="nb-card-accent ${sCls}"></div>
      <div class="nb-card-top">
        <div class="nb-card-teacher">
          <div class="teacher-avatar" style="background:${n.teacherColor}">${n.teacherName[0]}</div>
          <div><div class="teacher-name">${n.teacherName} 선생님</div><div class="teacher-class">${n.className}</div></div>
        </div>
        <div style="display:flex;align-items:center;gap:6px">
          ${n.hasAi?'<span style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:8px;background:#EDE9FE;color:#5B21B6">✨AI</span>':''}
          <span class="nb-status-badge ${sCls}">● ${sLabel}</span>
        </div>
      </div>
      ${weatherLabel?`<div class="nb-card-weather">${weatherLabel}</div>`:''}
      <div class="nb-card-content">${preview}</div>
      <div class="nb-children-row">${childChips}</div>
      <div class="nb-card-footer">
        <span class="nb-meta-item">👶 ${n.childCount}명</span>
        <span class="nb-meta-item">📸 ${n.photoCount}</span>
        <span class="nb-meta-item">💬 ${n.commentCount}</span>
        <span class="nb-meta-item">👀 ${n.readCount}/${n.childCount}</span>
        <span style="margin-left:auto;font-size:11px;color:var(--text-muted)">${timeLabel}</span>
        <div class="nb-card-actions" onclick="event.stopPropagation()">
          <div class="nb-act-btn" title="수정" onclick="openWritePanelEdit('${n.id}')">✏️</div>
          ${n.status==='published'?`<div class="nb-act-btn" title="회수" onclick="recallNotice('${n.id}')">↩️</div>`:''}
          <div class="nb-act-btn" title="삭제" onclick="deleteNotice('${n.id}')">🗑️</div>
        </div>
      </div>
    </div>`;
}

