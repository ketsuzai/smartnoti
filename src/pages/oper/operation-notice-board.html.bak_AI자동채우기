   8. 작성 패널
═══════════════════════════════════════════════ */
function openWritePanel() {
  writeMode = 'new';
  editTargetId = null;
  const today = new Date().toISOString().slice(0,10);
  const defaultClass = selectedClassId || CLASSES[0].id;
  writeState = {
    date: today,
    classId: defaultClass,
    weather: '맑음',
    temperature: '',
    content: '',
    selectedChildren: CHILDREN.filter(c=>c.classId===defaultClass).map(c=>c.id),
    childData: {},
  };
  CHILDREN.filter(c=>c.classId===defaultClass).forEach(c=>{
    writeState.childData[c.id] = defaultChildData();
  });
  document.getElementById('writePanelTitle').textContent = '✏️ 알림장 작성';
  renderWritePanel();
  document.getElementById('panelOverlay').classList.add('show');
  document.getElementById('writePanel').classList.add('show');
}

function openWritePanelEdit(id) {
  const n = allNotices.find(x=>x.id===id);
  if(!n) return;
  writeMode = 'edit';
  editTargetId = id;
  writeState = {
    date: n.date,
    classId: n.classId,
    weather: n.weather,
    temperature: n.temperature,
    content: n.content,
    selectedChildren: n.children.map(c=>c.childId),
    childData: {},
  };
  n.children.forEach(c => {
    writeState.childData[c.childId] = {
      attendance: c.attendance,
      mood: c.mood,
      health: [c.health].filter(Boolean),
      mealBreakfast: c.mealBreakfast,
      mealLunch: c.mealLunch,
      mealSnackAm: c.mealSnackAm,
      mealSnackPm: c.mealSnackPm,
      napStatus: c.napStatus,
      napStart: c.napStart,
      napEnd: c.napEnd,
      toiletCount: c.toiletCount,
      toiletStatus: c.toiletStatus,
      activityIndoor: [...(c.activityIndoor||[])],
      activityOutdoor: [...(c.activityOutdoor||[])],
      individualMemo: c.individualMemo,
    };
  });
  document.getElementById('writePanelTitle').textContent = '✏️ 알림장 수정';
  renderWritePanel();
  document.getElementById('panelOverlay').classList.add('show');
  document.getElementById('writePanel').classList.add('show');
}

