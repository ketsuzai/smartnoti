<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>알림장 — 키드키즈</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="operation-sidebar.js" defer></script>
<style>
:root {
  --sidebar-bg:#0C2D48; --sidebar-hover:#1A4A6B; --sidebar-active:#1E5580;
  --sidebar-text:#B8D9F0; --sidebar-width:240px; --header-height:60px;
  --accent:#0EA5E9; --accent-light:#E0F2FE; --accent-dark:#0284C7;
  --bg-base:#F0F7FF; --bg-surface:#FFFFFF;
  --text-primary:#0C2D48; --text-secondary:#4B7FA3; --text-muted:#94B8D0;
  --border-light:#DBEAFE; --border-medium:#BAD9F7;
  --green:#10B981; --green-bg:#D1FAE5; --green-text:#065F46;
  --blue:#3B82F6; --blue-bg:#DBEAFE; --blue-text:#1E40AF;
  --amber:#F59E0B; --amber-bg:#FEF3C7; --amber-text:#92400E;
  --red:#EF4444; --red-bg:#FEE2E2; --red-text:#991B1B;
  --purple:#8B5CF6; --purple-bg:#EDE9FE; --purple-text:#5B21B6;
  --shadow-sm:0 1px 3px rgba(12,45,72,0.06);
  --shadow-md:0 4px 12px rgba(12,45,72,0.09);
  --shadow-lg:0 8px 28px rgba(12,45,72,0.13);
  --r-sm:6px; --r-md:10px; --r-lg:14px; --r-xl:18px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Pretendard',sans-serif;background:var(--bg-base);color:var(--text-primary);display:flex;height:100vh;overflow:hidden;}

/* 사이드바 CSS → operation-sidebar.js 에서 주입 */

/* MAIN */
.main-wrap{margin-left:var(--sidebar-width);flex:1;display:flex;flex-direction:column;overflow:hidden;}
.topbar{height:var(--header-height);background:var(--bg-surface);border-bottom:1px solid var(--border-light);display:flex;align-items:center;padding:0 24px;gap:12px;box-shadow:var(--shadow-sm);flex-shrink:0;z-index:50;}
.breadcrumb{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-secondary);flex:1;}
.breadcrumb .cur{color:var(--text-primary);font-weight:600;}
.bc-sep{color:var(--text-muted);font-size:11px;}
.class-filter-wrap{display:flex;align-items:center;gap:8px;background:var(--bg-base);border:1.5px solid var(--border-light);border-radius:var(--r-md);padding:5px 12px;transition:0.18s;}
.class-filter-wrap:focus-within{border-color:var(--accent);background:#fff;}
.class-filter-label{font-size:11px;color:var(--text-secondary);font-weight:600;white-space:nowrap;}
.class-filter-divider{width:1px;height:14px;background:var(--border-medium);}
.class-select-wrap{position:relative;}
.class-select{appearance:none;border:none;background:transparent;font-size:13px;font-weight:700;color:var(--text-primary);cursor:pointer;font-family:'Pretendard',sans-serif;outline:none;padding-right:20px;min-width:120px;}
.class-select-arrow{position:absolute;right:0;top:50%;transform:translateY(-50%);pointer-events:none;color:var(--text-muted);font-size:11px;}
.class-select option.disabled-opt{color:#C0C0C0;background:#F9FAFB;}
.topbar-right{display:flex;align-items:center;gap:10px;}
.topbar-date{font-size:12px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;}
.icon-btn{width:36px;height:36px;border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;background:var(--bg-base);border:1px solid var(--border-light);cursor:pointer;transition:0.18s;font-size:16px;position:relative;}
.icon-btn:hover{background:var(--accent-light);border-color:var(--accent);}
.notif-dot::after{content:'';position:absolute;top:6px;right:6px;width:6px;height:6px;border-radius:50%;background:var(--red);border:1.5px solid var(--bg-surface);}

/* CONTENT */
.content{flex:1;overflow-y:auto;padding:22px 24px;}
.content::-webkit-scrollbar{width:5px;}
.content::-webkit-scrollbar-thumb{background:var(--border-medium);border-radius:3px;}
.page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;}
.page-title{font-size:21px;font-weight:800;letter-spacing:-0.5px;}
.page-sub{font-size:13px;color:var(--text-secondary);margin-top:3px;}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px;}
.kpi-card{background:var(--bg-surface);border-radius:var(--r-lg);padding:16px 18px;box-shadow:var(--shadow-sm);border:1px solid var(--border-light);display:flex;align-items:center;gap:12px;transition:box-shadow 0.2s;}
.kpi-card:hover{box-shadow:var(--shadow-md);}
.kpi-ico{width:46px;height:46px;border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;font-size:21px;flex-shrink:0;}
.kpi-ico.sky{background:#E0F2FE;} .kpi-ico.green{background:var(--green-bg);}
.kpi-ico.amber{background:var(--amber-bg);} .kpi-ico.red{background:var(--red-bg);}
.kpi-label{font-size:11px;color:var(--text-secondary);font-weight:500;margin-bottom:2px;}
.kpi-value{font-size:24px;font-weight:800;color:var(--text-primary);letter-spacing:-0.8px;line-height:1;}
.kpi-sub{font-size:11px;color:var(--text-muted);margin-top:2px;}

/* FILTER BAR */
.filter-bar{background:var(--bg-surface);border:1px solid var(--border-light);border-radius:var(--r-lg);padding:12px 18px;margin-bottom:14px;display:flex;flex-wrap:wrap;align-items:center;gap:10px;box-shadow:var(--shadow-sm);}
.filter-group{display:flex;align-items:center;gap:6px;}
.filter-label{font-size:11px;font-weight:600;color:var(--text-secondary);white-space:nowrap;}
.filter-select,.filter-input{height:34px;padding:0 10px;border:1.5px solid var(--border-light);border-radius:var(--r-md);font-size:12px;font-weight:500;color:var(--text-primary);background:#fff;font-family:'Pretendard',sans-serif;transition:border-color 0.18s;outline:none;}
.filter-select:focus,.filter-input:focus{border-color:var(--accent);}
.filter-select{cursor:pointer;}
.filter-divider{width:1px;height:22px;background:var(--border-light);}
.btn{display:inline-flex;align-items:center;gap:6px;height:36px;padding:0 16px;border-radius:var(--r-md);font-size:13px;font-weight:600;font-family:'Pretendard',sans-serif;cursor:pointer;border:none;transition:0.18s;white-space:nowrap;}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover{background:var(--accent-dark);}
.btn-outline{background:#fff;color:var(--text-primary);border:1.5px solid var(--border-medium);}
.btn-outline:hover{border-color:var(--accent);color:var(--accent-dark);background:var(--accent-light);}
.btn-sm{height:30px;padding:0 12px;font-size:12px;}
.btn-danger{background:var(--red-bg);color:var(--red-text);border:1.5px solid #FECACA;}
.btn-danger:hover{background:var(--red);color:#fff;}

/* ACTION BAR */
.action-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px;}

/* 날짜별 그룹 목록 */
.date-group{margin-bottom:16px;}
.date-group-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;padding:0 2px;}
.date-group-label{font-size:14px;font-weight:800;color:var(--text-primary);}
.date-group-meta{font-size:12px;color:var(--text-muted);}
.date-group-line{flex:1;height:1px;background:var(--border-light);}

/* 알림장 카드 */
.nb-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:12px;}
.nb-card{background:var(--bg-surface);border:1px solid var(--border-light);border-radius:var(--r-lg);padding:16px;cursor:pointer;transition:all 0.2s;box-shadow:var(--shadow-sm);position:relative;overflow:hidden;}
.nb-card:hover{box-shadow:var(--shadow-md);border-color:var(--accent);transform:translateY(-1px);}
.nb-card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;}
.nb-card-teacher{display:flex;align-items:center;gap:8px;}
.teacher-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:#fff;flex-shrink:0;}
.teacher-name{font-size:13px;font-weight:700;color:var(--text-primary);}
.teacher-class{font-size:11px;color:var(--text-secondary);}
.nb-status-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:10px;font-size:11px;font-weight:700;}
.nb-status-badge.published{background:var(--green-bg);color:var(--green-text);}
.nb-status-badge.draft{background:var(--amber-bg);color:var(--amber-text);}
.nb-status-badge.recalled{background:#F3F4F6;color:#6B7280;}
.nb-status-badge.scheduled{background:var(--purple-bg);color:var(--purple-text);}
.nb-card-content{font-size:13px;color:var(--text-primary);line-height:1.6;margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.nb-card-weather{font-size:12px;color:var(--text-secondary);margin-bottom:10px;display:flex;align-items:center;gap:6px;}
/* 원아 아바타 행 */
.nb-children-row{display:flex;align-items:center;gap:-4px;margin-bottom:10px;flex-wrap:wrap;gap:4px;}
.child-chip{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:10px;background:var(--bg-base);border:1px solid var(--border-light);font-size:11px;font-weight:600;color:var(--text-primary);}
.child-chip-dot{width:7px;height:7px;border-radius:50%;}
.child-chip.read{border-color:#A7F3D0;background:#F0FDF4;}
.child-chip.unread{border-color:#FED7AA;background:#FFF7ED;}
.nb-card-footer{display:flex;align-items:center;justify-content:space-between;padding-top:10px;border-top:1px solid var(--border-light);}
.nb-meta-item{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--text-muted);}
.nb-card-actions{display:flex;gap:4px;}
.nb-act-btn{width:28px;height:28px;border-radius:var(--r-sm);border:1px solid var(--border-light);background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:0.18s;}
.nb-act-btn:hover{background:var(--accent-light);border-color:var(--accent);}
.nb-card-accent{position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:var(--r-lg) 0 0 var(--r-lg);}
.nb-card-accent.published{background:var(--green);}
.nb-card-accent.draft{background:var(--amber);}
.nb-card-accent.recalled{background:#9CA3AF;}
.nb-card-accent.scheduled{background:var(--purple);}

/* 빈 상태 */
.empty-state{text-align:center;padding:60px 24px;color:var(--text-muted);background:var(--bg-surface);border-radius:var(--r-lg);border:1px solid var(--border-light);}
.empty-state-icon{font-size:44px;margin-bottom:12px;}
.empty-state-text{font-size:15px;font-weight:700;color:var(--text-secondary);}
.empty-state-sub{font-size:13px;margin-top:6px;}

/* ── OVERLAY ── */
.panel-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:300;opacity:0;pointer-events:none;transition:opacity 0.25s;}
.panel-overlay.show{opacity:1;pointer-events:all;}

/* ── 상세 뷰어 패널 (600px) ── */
.view-panel{position:fixed;right:0;top:0;height:100vh;width:600px;background:#fff;z-index:400;box-shadow:-8px 0 32px rgba(12,45,72,0.12);display:flex;flex-direction:column;transform:translateX(100%);transition:transform 0.3s cubic-bezier(.4,0,.2,1);}
.view-panel.show{transform:translateX(0);}

/* ── 작성 패널 (860px) ── */
.write-panel{position:fixed;right:0;top:0;height:100vh;width:860px;background:#fff;z-index:400;box-shadow:-8px 0 32px rgba(12,45,72,0.12);display:flex;flex-direction:column;transform:translateX(100%);transition:transform 0.3s cubic-bezier(.4,0,.2,1);}
.write-panel.show{transform:translateX(0);}

/* 공통 패널 헤더 */
.panel-header{height:60px;padding:0 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border-light);flex-shrink:0;}
.panel-title{font-size:16px;font-weight:800;display:flex;align-items:center;gap:8px;}
.panel-title-sub{font-size:12px;color:var(--text-secondary);font-weight:500;margin-left:4px;}
.panel-header-actions{display:flex;align-items:center;gap:8px;}
.panel-close{width:32px;height:32px;border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;cursor:pointer;background:var(--bg-base);border:1px solid var(--border-light);font-size:16px;transition:0.18s;color:var(--text-secondary);}
.panel-close:hover{background:var(--red-bg);border-color:#FECACA;color:var(--red);}

/* 뷰어 내부 */
.panel-body{flex:1;overflow-y:auto;padding:0;}
.panel-body::-webkit-scrollbar{width:4px;}
.panel-body::-webkit-scrollbar-thumb{background:var(--border-medium);border-radius:2px;}
.panel-footer{padding:14px 20px;border-top:1px solid var(--border-light);flex-shrink:0;display:flex;gap:8px;justify-content:flex-end;background:#FAFCFF;}

/* 뷰어 — 날짜·날씨 헤더 */
.view-date-bar{padding:16px 20px;border-bottom:1px solid var(--border-light);display:flex;align-items:center;justify-content:space-between;background:linear-gradient(135deg,#F0F7FF,#E0F2FE);}
.view-date-big{font-size:18px;font-weight:800;color:var(--text-primary);}
.view-meta-row{display:flex;align-items:center;gap:12px;margin-top:4px;font-size:12px;color:var(--text-secondary);}
.view-weather-icon{font-size:22px;}
.view-teacher-chip{display:flex;align-items:center;gap:6px;background:rgba(255,255,255,0.8);padding:4px 10px;border-radius:10px;border:1px solid var(--border-light);}

/* 뷰어 — 공통 본문 */
.view-section{padding:16px 20px;border-bottom:1px solid var(--border-light);}
.view-section-title{font-size:11px;font-weight:800;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.view-section-title::after{content:'';flex:1;height:1px;background:var(--border-light);}
.view-content-text{font-size:13.5px;line-height:1.8;color:var(--text-primary);}

/* 뷰어 — 원아 탭 */
.child-tabs{display:flex;overflow-x:auto;border-bottom:1px solid var(--border-light);flex-shrink:0;padding:0 20px;gap:2px;}
.child-tabs::-webkit-scrollbar{height:3px;}
.child-tabs::-webkit-scrollbar-thumb{background:var(--border-medium);border-radius:2px;}
.child-tab{display:flex;align-items:center;gap:6px;padding:10px 14px;font-size:12px;font-weight:600;color:var(--text-secondary);cursor:pointer;border-bottom:2.5px solid transparent;white-space:nowrap;transition:0.18s;flex-shrink:0;}
.child-tab:hover{color:var(--accent-dark);}
.child-tab.active{color:var(--accent-dark);border-bottom-color:var(--accent);}
.child-tab-dot{width:8px;height:8px;border-radius:50%;}
.child-tab-unread{width:7px;height:7px;border-radius:50%;background:var(--red);flex-shrink:0;}

/* 뷰어 — 체크필드 그리드 */
.check-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px;}
.check-item{background:var(--bg-base);border:1px solid var(--border-light);border-radius:var(--r-md);padding:10px 12px;display:flex;flex-direction:column;gap:3px;}
.check-item-label{font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;}
.check-item-value{font-size:13px;font-weight:700;color:var(--text-primary);display:flex;align-items:center;gap:5px;}

/* 식사 행 */
.meal-row{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px;}
.meal-cell{background:var(--bg-base);border:1px solid var(--border-light);border-radius:var(--r-md);padding:8px 10px;text-align:center;}
.meal-cell-label{font-size:10px;color:var(--text-muted);font-weight:600;margin-bottom:4px;}
.meal-cell-value{font-size:12px;font-weight:700;color:var(--text-primary);}

/* 활동 태그 */
.activity-tags{display:flex;flex-wrap:wrap;gap:5px;}
.act-tag{padding:3px 9px;border-radius:10px;font-size:11px;font-weight:600;background:var(--accent-light);color:var(--accent-dark);border:1px solid var(--border-medium);}
.act-tag.outdoor{background:var(--green-bg);color:var(--green-text);border-color:#A7F3D0;}

/* 사진 그리드 */
.photo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;}
.photo-thumb{aspect-ratio:1;border-radius:var(--r-md);overflow:hidden;cursor:pointer;background:var(--bg-base);border:1px solid var(--border-light);display:flex;align-items:center;justify-content:center;font-size:24px;color:var(--text-muted);}
.photo-thumb img{width:100%;height:100%;object-fit:cover;}

/* 댓글 */
.comment-area{padding:16px 20px;}
.comment-list{display:flex;flex-direction:column;gap:12px;margin-bottom:14px;}
.comment-item{display:flex;align-items:flex-start;gap:10px;}
.comment-item.reply{margin-left:36px;}
.comment-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:#fff;flex-shrink:0;}
.comment-bubble{flex:1;background:var(--bg-base);border:1px solid var(--border-light);border-radius:0 var(--r-md) var(--r-md) var(--r-md);padding:9px 12px;}
.comment-bubble.teacher{background:#EFF6FF;border-color:#BFDBFE;}
.comment-meta{display:flex;align-items:center;gap:6px;margin-bottom:4px;}
.comment-author{font-size:12px;font-weight:700;color:var(--text-primary);}
.comment-role{font-size:10px;font-weight:700;padding:1px 6px;border-radius:6px;}
.comment-role.teacher{background:var(--blue-bg);color:var(--blue-text);}
.comment-role.parent{background:var(--green-bg);color:var(--green-text);}
.comment-time{font-size:10px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;margin-left:auto;}
.comment-text{font-size:13px;color:var(--text-primary);line-height:1.6;}
.comment-actions{display:flex;gap:8px;margin-top:4px;}
.comment-act{font-size:11px;color:var(--text-muted);cursor:pointer;background:none;border:none;font-family:'Pretendard',sans-serif;padding:0;}
.comment-act:hover{color:var(--accent-dark);}
.comment-reply-btn{font-size:11px;color:var(--accent-dark);cursor:pointer;font-weight:600;background:none;border:none;font-family:'Pretendard',sans-serif;padding:0;margin-top:4px;}
.comment-input-wrap{display:flex;gap:8px;align-items:flex-end;}
.comment-input{flex:1;border:1.5px solid var(--border-light);border-radius:var(--r-md);padding:9px 12px;font-size:13px;font-family:'Pretendard',sans-serif;resize:none;outline:none;transition:border-color 0.18s;min-height:40px;max-height:100px;}
.comment-input:focus{border-color:var(--accent);}
.comment-send-btn{height:40px;padding:0 14px;background:var(--accent);color:#fff;border:none;border-radius:var(--r-md);font-size:13px;font-weight:700;font-family:'Pretendard',sans-serif;cursor:pointer;flex-shrink:0;transition:0.18s;}
.comment-send-btn:hover{background:var(--accent-dark);}

/* ── 작성 패널 내부 ── */
.write-body{flex:1;overflow-y:auto;display:flex;flex-direction:column;}
.write-body::-webkit-scrollbar{width:4px;}
.write-body::-webkit-scrollbar-thumb{background:var(--border-medium);border-radius:2px;}

/* 작성 — 기본설정 섹션 */
.write-section{padding:18px 24px;border-bottom:1px solid var(--border-light);}
.write-section-title{font-size:12px;font-weight:800;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.write-section-title .ws-icon{font-size:15px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:12px;}
.form-row.col3{grid-template-columns:1fr 1fr 1fr;}
.form-row.full{grid-template-columns:1fr;margin-bottom:0;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-label{font-size:12px;font-weight:700;color:var(--text-secondary);display:flex;align-items:center;gap:4px;}
.form-label .req{color:var(--red);font-size:10px;}
.form-input,.form-select{height:38px;padding:0 12px;border:1.5px solid var(--border-light);border-radius:var(--r-md);font-size:13px;font-family:'Pretendard',sans-serif;color:var(--text-primary);transition:border-color 0.18s;outline:none;background:#fff;}
.form-input:focus,.form-select:focus{border-color:var(--accent);}
.form-textarea{padding:10px 12px;border:1.5px solid var(--border-light);border-radius:var(--r-md);font-size:13px;font-family:'Pretendard',sans-serif;color:var(--text-primary);transition:border-color 0.18s;outline:none;resize:vertical;min-height:100px;background:#fff;line-height:1.7; width:100%}
.form-textarea:focus{border-color:var(--accent);}

/* AI 버튼 */
.ai-toolbar{display:flex;gap:6px;margin-top:6px;}
.ai-btn{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:var(--r-md);font-size:12px;font-weight:700;cursor:pointer;border:none;font-family:'Pretendard',sans-serif;transition:0.18s;}
.ai-btn.generate{background:linear-gradient(135deg,#6366F1,#8B5CF6);color:#fff;}
.ai-btn.generate:hover{background:linear-gradient(135deg,#4F46E5,#7C3AED);}
.ai-btn.polish{background:linear-gradient(135deg,#0EA5E9,#38BDF8);color:#fff;}
.ai-btn.polish:hover{background:linear-gradient(135deg,#0284C7,#0EA5E9);}
.ai-btn.template{background:#fff;color:var(--text-primary);border:1.5px solid var(--border-medium);}
.ai-btn.template:hover{border-color:var(--accent);color:var(--accent-dark);}

/* 원아 선택 체크 */
.child-select-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.child-select-card{border:2px solid var(--border-light);border-radius:var(--r-md);padding:10px;cursor:pointer;transition:0.18s;text-align:center;}
.child-select-card:hover{border-color:var(--accent);background:var(--accent-light);}
.child-select-card.selected{border-color:var(--accent);background:var(--accent-light);}
.child-select-card.selected .csc-name{color:var(--accent-dark);}
.csc-avatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:#fff;margin:0 auto 6px;}
.csc-name{font-size:12px;font-weight:700;color:var(--text-primary);}
.csc-check{width:16px;height:16px;border-radius:50%;border:2px solid var(--border-medium);margin:4px auto 0;display:flex;align-items:center;justify-content:center;font-size:9px;color:#fff;}
.child-select-card.selected .csc-check{background:var(--accent);border-color:var(--accent);}

/* 원아별 카드 입력 그리드 */
.write-child-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:14px;padding:18px 24px;}
.write-child-card{border:1.5px solid var(--border-light);border-radius:var(--r-lg);overflow:hidden;}
.wcc-header{display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--bg-base);border-bottom:1px solid var(--border-light);}
.wcc-avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;flex-shrink:0;}
.wcc-name{font-size:14px;font-weight:800;color:var(--text-primary);}
.wcc-body{padding:12px 14px;display:flex;flex-direction:column;gap:10px;}

/* 체크 버튼 그룹 */
.check-btn-group{display:flex;flex-wrap:wrap;gap:5px;}
.check-btn{padding:4px 10px;border-radius:8px;border:1.5px solid var(--border-light);background:#fff;font-size:11px;font-weight:600;cursor:pointer;font-family:'Pretendard',sans-serif;transition:0.18s;color:var(--text-secondary);}
.check-btn:hover{border-color:var(--accent);color:var(--accent-dark);}
.check-btn.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.check-btn.active.green{background:var(--green);border-color:var(--green);}
.check-btn.active.red{background:var(--red);border-color:var(--red);}
.check-btn.active.amber{background:var(--amber);border-color:var(--amber);}
.wcc-field-label{font-size:11px;font-weight:700;color:var(--text-secondary);margin-bottom:4px;}

/* 낮잠 시간 입력 */
.nap-time-row{display:flex;align-items:center;gap:6px;margin-top:6px;}
.nap-time-input{width:80px;height:30px;padding:0 8px;border:1.5px solid var(--border-light);border-radius:var(--r-sm);font-size:12px;font-family:'Pretendard',sans-serif;outline:none;}
.nap-time-input:focus{border-color:var(--accent);}
.nap-time-sep{font-size:12px;color:var(--text-muted);}

/* 활동 태그 선택 */
.tag-select-wrap{display:flex;flex-wrap:wrap;gap:4px;}
.tag-btn{padding:3px 9px;border-radius:8px;border:1.5px solid var(--border-light);background:#fff;font-size:11px;font-weight:600;cursor:pointer;font-family:'Pretendard',sans-serif;transition:0.18s;color:var(--text-secondary);}
.tag-btn:hover{border-color:var(--accent);}
.tag-btn.active{background:var(--accent-light);color:var(--accent-dark);border-color:var(--accent);}
.tag-btn.active.outdoor{background:var(--green-bg);color:var(--green-text);border-color:#A7F3D0;}

/* 날씨 선택 버튼 */
.weather-btn-group{display:flex;gap:6px;flex-wrap:wrap;}
.weather-btn{padding:5px 12px;border-radius:var(--r-md);border:1.5px solid var(--border-light);background:#fff;font-size:12px;cursor:pointer;font-family:'Pretendard',sans-serif;transition:0.18s;display:flex;align-items:center;gap:4px;}
.weather-btn:hover{border-color:var(--accent);}
.weather-btn.active{border-color:var(--accent);background:var(--accent-light);}

/* AI 예문 모달 */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:600;display:none;align-items:center;justify-content:center;}
.modal-overlay.show{display:flex;}
.modal-box{background:#fff;border-radius:var(--r-xl);width:580px;max-width:94vw;max-height:80vh;display:flex;flex-direction:column;box-shadow:var(--shadow-lg);animation:modalIn 0.22s ease;}
@keyframes modalIn{from{opacity:0;transform:scale(0.95)}to{opacity:1;transform:scale(1)}}
.modal-header{padding:18px 22px 14px;border-bottom:1px solid var(--border-light);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.modal-title{font-size:16px;font-weight:800;}
.modal-close{width:30px;height:30px;border-radius:var(--r-sm);border:1px solid var(--border-light);background:var(--bg-base);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--text-secondary);}
.modal-close:hover{background:var(--red-bg);color:var(--red);border-color:#FECACA;}
.modal-body{flex:1;overflow-y:auto;padding:18px 22px;}
.modal-footer{padding:12px 22px;border-top:1px solid var(--border-light);display:flex;gap:8px;justify-content:flex-end;flex-shrink:0;}

/* 예문 카드 */
.template-list{display:flex;flex-direction:column;gap:8px;}
.template-card{border:1.5px solid var(--border-light);border-radius:var(--r-md);padding:12px 14px;cursor:pointer;transition:0.18s;}
.template-card:hover{border-color:var(--accent);background:var(--accent-light);}
.template-card-title{font-size:13px;font-weight:700;color:var(--text-primary);margin-bottom:4px;display:flex;align-items:center;gap:6px;}
.template-card-preview{font-size:12px;color:var(--text-secondary);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.template-card-meta{display:flex;align-items:center;gap:8px;margin-top:6px;}
.template-tag{font-size:10px;font-weight:700;padding:1px 7px;border-radius:8px;background:var(--bg-base);border:1px solid var(--border-light);color:var(--text-secondary);}
.template-tag.ai{background:var(--purple-bg);color:var(--purple-text);border-color:#C4B5FD;}
.template-use-cnt{font-size:10px;color:var(--text-muted);margin-left:auto;}

/* AI 로딩 */
.ai-loading{display:none;align-items:center;justify-content:center;gap:10px;padding:20px;font-size:13px;color:var(--text-secondary);}
.ai-loading.show{display:flex;}
.ai-spinner{width:20px;height:20px;border:2.5px solid var(--border-light);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}

/* TOAST */
.toast-wrap{position:fixed;bottom:24px;right:24px;z-index:700;display:flex;flex-direction:column;gap:8px;}
.toast{background:#1A1D2E;color:#fff;padding:10px 16px;border-radius:var(--r-md);font-size:13px;box-shadow:var(--shadow-lg);animation:toastIn 0.25s ease;display:flex;align-items:center;gap:8px;}
.toast.success{background:var(--green);}
.toast.error{background:var(--red);}
.toast.ai{background:linear-gradient(135deg,#6366F1,#8B5CF6);}
@keyframes toastIn{from{opacity:0;transform:translateX(12px)}to{opacity:1;transform:translateX(0)}}
</style>
</head>
