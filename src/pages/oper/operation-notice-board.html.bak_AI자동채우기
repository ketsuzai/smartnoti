function changeWriteClass(classId) {
  writeState.classId = classId;
  const children = CHILDREN.filter(c=>c.classId===classId);
  writeState.selectedChildren = children.map(c=>c.id);
  writeState.childData = {};
  children.forEach(c=>{ writeState.childData[c.id] = defaultChildData(); });
  renderWritePanel();
}

function toggleChildSelect(cid) {
  const idx = writeState.selectedChildren.indexOf(cid);
  if(idx>-1) writeState.selectedChildren.splice(idx,1);
  else { writeState.selectedChildren.push(cid); if(!writeState.childData[cid]) writeState.childData[cid]=defaultChildData(); }
  renderWritePanel();
}

function selectAllChildren() {
  writeState.selectedChildren = CHILDREN.filter(c=>c.classId===writeState.classId).map(c=>c.id);
  writeState.selectedChildren.forEach(cid=>{ if(!writeState.childData[cid]) writeState.childData[cid]=defaultChildData(); });
  renderWritePanel();
}

function deselectAllChildren() { writeState.selectedChildren=[]; renderWritePanel(); }

function setWeather(val, btn) {
  writeState.weather = val;
  btn.closest('.weather-btn-group').querySelectorAll('.weather-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function setCd(cid, key, val, btn) {
  if(!writeState.childData[cid]) writeState.childData[cid]=defaultChildData();
  writeState.childData[cid][key] = val;
  const group = btn.closest('.check-btn-group');
  if(group) group.querySelectorAll('.check-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function setCdDirect(cid, key, val) {
  if(!writeState.childData[cid]) writeState.childData[cid]=defaultChildData();
  writeState.childData[cid][key]=val;
}

function toggleHealth(cid, val, btn) {
  if(!writeState.childData[cid]) writeState.childData[cid]=defaultChildData();
  const arr = writeState.childData[cid].health || [];
  const idx = arr.indexOf(val);
  if(idx>-1) arr.splice(idx,1); else arr.push(val);
  writeState.childData[cid].health = arr;
  btn.classList.toggle('active');
}

function toggleActivity(cid, type, val, btn) {
  if(!writeState.childData[cid]) writeState.childData[cid]=defaultChildData();
  const key = type==='indoor' ? 'activityIndoor' : 'activityOutdoor';
  const arr = writeState.childData[cid][key] || [];
  const idx = arr.indexOf(val);
  if(idx>-1) arr.splice(idx,1); else arr.push(val);
  writeState.childData[cid][key]=arr;
  btn.classList.toggle('active');
  if(type==='outdoor') btn.classList.toggle('outdoor', btn.classList.contains('active'));
}

function closeWritePanel() {
  document.getElementById('writePanel').classList.remove('show');
  document.getElementById('panelOverlay').classList.remove('show');
}

function saveDraft() {
  writeState.content = document.getElementById('commonContent')?.value || writeState.content;
  saveNotice('draft');
  showToast('임시저장 되었습니다.', 'success');
  closeWritePanel();
  applyFilters();
}

function submitPublish() {
  writeState.content = document.getElementById('commonContent')?.value || writeState.content;
  if(!writeState.selectedChildren.length){ showToast('대상 원아를 1명 이상 선택해주세요.','error'); return; }
  saveNotice('published');
  showToast('알림장이 발행되었습니다! 학부모에게 전달됩니다.','success');
  closeWritePanel();
  applyFilters();
}

function saveNotice(status) {
  const cls = CLASSES.find(c=>c.id===writeState.classId);
  const now = new Date().toLocaleString('ko-KR',{year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'}).replace(/\. /g,'-').replace('.',':');

  const childrenData = writeState.selectedChildren.map(cid=>{
    const child = CHILDREN.find(x=>x.id===cid);
    const cd = writeState.childData[cid] || defaultChildData();
    return {
      childId:cid, childName:child?.name||'', color:child?.color||'#888',
      attendance:cd.attendance, mood:cd.mood, health:(cd.health||['양호'])[0],
      mealBreakfast:cd.mealBreakfast, mealLunch:cd.mealLunch, mealSnackAm:cd.mealSnackAm, mealSnackPm:cd.mealSnackPm,
      napStatus:cd.napStatus, napStart:cd.napStart||'', napEnd:cd.napEnd||'',
      toiletCount:cd.toiletCount||0, toiletStatus:cd.toiletStatus,
      activityIndoor:cd.activityIndoor||[], activityOutdoor:cd.activityOutdoor||[],
      individualMemo:cd.individualMemo||'', isRead:false, commentCount:0, comments:[]
    };
  });

  if(writeMode==='edit' && editTargetId) {
    const idx = allNotices.findIndex(x=>x.id===editTargetId);
    if(idx>-1) {
      allNotices[idx] = { ...allNotices[idx], classId:writeState.classId, className:cls?.name||'', date:writeState.date, status, content:writeState.content, weather:writeState.weather, temperature:writeState.temperature, children:childrenData, childCount:childrenData.length, readCount:0, commentCount:0, publishedAt:status==='published'?now:'' };
    }
  } else {
    const newId = 'NB' + Date.now();
    allNotices.unshift({ id:newId, classId:writeState.classId, className:cls?.name||'', teacherId:'TCH_CURRENT', teacherName:SESSION.userName, teacherColor:'#0EA5E9', date:writeState.date, status, title:'', content:writeState.content, weather:writeState.weather, temperature:writeState.temperature, childCount:childrenData.length, readCount:0, commentCount:0, photoCount:0, hasAi:false, publishedAt:status==='published'?now:'', isScheduled:false, children:childrenData });
  }
}

/* ═══════════════════════════════════════════════
   9. 알림장 회수 / 삭제
═══════════════════════════════════════════════ */
function recallNotice(id) {
  if(!confirm('발행된 알림장을 회수하시겠습니까?\n학부모에게 더 이상 표시되지 않습니다.')) return;
  const n = allNotices.find(x=>x.id===id);
  if(n) n.status='recalled';
  applyFilters();
  showToast('알림장이 회수되었습니다.');
}

function deleteNotice(id) {
  if(!confirm('알림장을 삭제하시겠습니까?\n삭제 후 복구할 수 없습니다.')) return;
  allNotices = allNotices.filter(x=>x.id!==id);
  applyFilters();
  showToast('알림장이 삭제되었습니다.');
}

/* ═══════════════════════════════════════════════
   10. 예문 라이브러리
═══════════════════════════════════════════════ */
function openTemplateModal() {
  document.getElementById('templateModal').classList.add('show');
  renderTemplateList();
}
function closeTemplateModal() { document.getElementById('templateModal').classList.remove('show'); }

function renderTemplateList() {
  const cat = document.getElementById('tmplCategoryFilter').value;
  const kw  = document.getElementById('tmplSearch').value.trim();
  const list = templateData.filter(t=>(!cat||t.category===cat) && (!kw||t.title.includes(kw)||t.content.includes(kw)));
  document.getElementById('templateList').innerHTML = list.length ? list.map(t=>`
    <div class="template-card" onclick="useTemplate('${t.id}')">
      <div class="template-card-title">
        <span style="font-size:11px;font-weight:700;padding:1px 7px;border-radius:6px;background:var(--accent-light);color:var(--accent-dark)">${t.category}</span>
        ${t.title}
        ${t.isAi?'<span class="template-tag ai">✨AI</span>':''}
      </div>
      <div class="template-card-preview">${t.content}</div>
      <div class="template-card-meta">
        ${t.tags.map(tg=>`<span class="template-tag">${tg}</span>`).join('')}
        <span class="template-use-cnt">사용 ${t.useCount}회</span>
      </div>
    </div>`).join('') : '<div style="text-align:center;padding:30px;color:var(--text-muted)">검색 결과가 없습니다.</div>';
}

function useTemplate(id) {
  const t = templateData.find(x=>x.id===id);
  if(!t) return;
  const ta = document.getElementById('commonContent');
  if(ta) ta.value = (ta.value ? ta.value + '\n\n' : '') + t.content;
  writeState.content = ta?.value || t.content;
  t.useCount++;
  closeTemplateModal();
  showToast('예문이 적용되었습니다.', 'success');
}

function openNewTemplateForm() {
  const title = prompt('예문 제목을 입력하세요:');
  if(!title) return;
  const content = prompt('예문 내용을 입력하세요:');
  if(!content) return;
  templateData.unshift({ id:'TPL'+Date.now(), category:'기타', title, content, isAi:false, useCount:0, tags:[] });
  renderTemplateList();
  showToast('예문이 추가되었습니다.', 'success');
}

/* ═══════════════════════════════════════════════
   11. AI 프리셋 기능
═══════════════════════════════════════════════ */
const AI_PRESETS_CONTENT = [
  (data)=>`오늘 ${data.className}은 ${data.weather} 날씨 속에 ${data.activities} 활동을 즐겼습니다. 아이들이 서로 협력하며 즐겁고 건강한 하루를 보냈으며, 급식도 잘 먹고 낮잠도 충분히 취했습니다. 오늘도 우리 ${data.className} 친구들과 함께 소중한 하루를 만들어 주셔서 감사합니다.`,
  (data)=>`${data.date} ${data.className} 알림장입니다. 오늘 날씨는 ${data.weather}이었으며 아이들이 활기차게 하루를 보냈습니다. ${data.activities} 등 다양한 활동을 통해 창의력과 사회성을 기르는 시간이었습니다. 내일도 건강하고 행복한 모습으로 만나요!`,
  (data)=>`오늘도 씩씩하고 즐겁게 하루를 보낸 ${data.className} 친구들입니다! ${data.weather} 날씨 덕분에 ${data.activities} 활동을 신나게 즐겼습니다. 아이들의 웃음소리가 가득한 하루였어요. 오늘 하루도 수고 많으셨습니다. 💛`,
];

function aiGenContent() {
  const ta = document.getElementById('commonContent');
  const loading = () => { showToast('✨ AI가 본문을 생성하고 있습니다…', 'ai'); };
  loading();
  const allActivities = writeState.selectedChildren.flatMap(cid=>{
    const cd = writeState.childData[cid]||{};
    return [...(cd.activityIndoor||[]), ...(cd.activityOutdoor||[])];
  });
  const uniqueActivities = [...new Set(allActivities)].slice(0,4);
  const cls = CLASSES.find(c=>c.id===writeState.classId);
  const data = { className:cls?.name||'', weather:writeState.weather||'맑음', date:writeState.date, activities:uniqueActivities.length ? uniqueActivities.join(', ') : '다양한' };
  const preset = AI_PRESETS_CONTENT[Math.floor(Math.random()*AI_PRESETS_CONTENT.length)];
  setTimeout(()=>{
    const result = preset(data);
    if(ta) ta.value = result;
    writeState.content = result;
    showToast('✨ AI 본문이 생성되었습니다!', 'ai');
  }, 900);
}

function aiPolishContent() {
  const ta = document.getElementById('commonContent');
  const original = ta?.value || '';
  if(!original.trim()){ showToast('먼저 본문을 입력해주세요.','error'); return; }
  showToast('✍️ 문장을 다듬고 있습니다…', 'ai');
  const polished = original
    .replace(/\.\s*/g, '. ')
    .replace(/합니다(?!\s)/g, '합니다. ')
    .replace(/이에요(?!\s)/g, '이에요. ')
    .replace(/  +/g, ' ')
    .trim();
  const prefix = '오늘도 소중한 하루를 함께해 주셔서 감사합니다. ';
  const suffix = ' 내일도 건강하고 행복한 모습으로 만나요! 💛';
  setTimeout(()=>{
    if(ta) ta.value = prefix + polished + suffix;
    writeState.content = ta.value;
    showToast('✍️ 문장 다듬기 완료!', 'ai');
  }, 700);
}

function aiGenChild(cid) {
  const child = CHILDREN.find(x=>x.id===cid);
  if(!child) return;
  showToast(`✨ ${child.name} 자동채우기 중…`, 'ai');
  const presets = [
    { attendance:'출석', mood:'매우좋음', health:['양호'], mealBreakfast:'잘먹음', mealLunch:'잘먹음', mealSnackAm:'잘먹음', mealSnackPm:'잘먹음', napStatus:'잘잠', napStart:'13:00', napEnd:'15:00', toiletCount:1, toiletStatus:'정상', activityIndoor:['블록놀이','그림그리기'], activityOutdoor:['산책'], individualMemo:'오늘 매우 활기차고 즐겁게 활동에 참여했습니다.' },
    { attendance:'출석', mood:'좋음', health:['양호'], mealBreakfast:'잘먹음', mealLunch:'조금먹음', mealSnackAm:'잘먹음', mealSnackPm:'잘먹음', napStatus:'조금잠', napStart:'13:10', napEnd:'14:20', toiletCount:0, toiletStatus:'없음', activityIndoor:['색칠하기','퍼즐'], activityOutdoor:['모래놀이'], individualMemo:'친구들과 사이좋게 어울려 놀았습니다.' },
    { attendance:'출석', mood:'보통', health:['콧물'], mealBreakfast:'잘먹음', mealLunch:'잘먹음', mealSnackAm:'조금먹음', mealSnackPm:'잘먹음', napStatus:'잘잠', napStart:'13:00', napEnd:'14:30', toiletCount:1, toiletStatus:'정상', activityIndoor:['독서','역할놀이'], activityOutdoor:['놀이터'], individualMemo:'콧물 증상이 조금 있어 실내 활동 위주로 진행했습니다.' },
  ];
  const preset = presets[Math.floor(Math.random()*presets.length)];
  setTimeout(()=>{
    writeState.childData[cid] = { ...writeState.childData[cid], ...preset };
    renderWritePanel();
    showToast(`✨ ${child.name} 자동채우기 완료!`, 'ai');
  }, 600);
}

/* ═══════════════════════════════════════════════
   12. 예약 발행
═══════════════════════════════════════════════ */
function openScheduleModal() {
  const today = new Date(); today.setDate(today.getDate()+1);
  document.getElementById('scheduleDate').value = today.toISOString().slice(0,10);
  document.getElementById('scheduleTime').value = '08:00';
  document.getElementById('scheduleModal').classList.add('show');
}
function closeScheduleModal() { document.getElementById('scheduleModal').classList.remove('show'); }
function submitSchedule() {
  const date = document.getElementById('scheduleDate').value;
  const time = document.getElementById('scheduleTime').value;
  if(!date||!time){ showToast('날짜와 시간을 입력해주세요.','error'); return; }
  writeState.content = document.getElementById('commonContent')?.value || writeState.content;
  writeState.scheduledAt = date + ' ' + time;
  writeState.isScheduled = true;
  saveNotice('scheduled');
  closeScheduleModal();
  showToast(`🕐 ${date} ${time} 예약 발행이 설정되었습니다.`, 'success');
  closeWritePanel();
  applyFilters();
}

/* ═══════════════════════════════════════════════
   13. 공통 유틸
═══════════════════════════════════════════════ */
function closePanels() {
  document.getElementById('viewPanel').classList.remove('show');
  document.getElementById('writePanel').classList.remove('show');
  document.getElementById('panelOverlay').classList.remove('show');
}

function showToast(msg, type='') {
  const wrap = document.getElementById('toastWrap');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  wrap.appendChild(el);
  setTimeout(()=>{ el.style.opacity='0'; el.style.transform='translateX(12px)'; el.style.transition='0.3s'; setTimeout(()=>el.remove(),300); }, 2500);
}
