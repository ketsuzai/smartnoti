function switchChildTab(idx) {
  currentViewChildIdx = idx;
  renderViewPanel();
}

function submitComment(noticeId, childIdx) {
  const input = document.getElementById('commentInput');
  const text = input.value.trim();
  if(!text) return;
  const n = allNotices.find(x=>x.id===noticeId);
  if(!n) return;
  const newComment = {
    id: 'CMT' + Date.now(),
    authorName: SESSION.userName + (IS_TEACHER?' 선생님':''),
    authorType: IS_TEACHER ? 'teacher' : 'org_admin',
    avatarColor: '#0EA5E9',
    content: text,
    createdAt: new Date().toLocaleTimeString('ko-KR',{hour:'2-digit',minute:'2-digit'}),
    isEdited: false, replies: []
  };
  n.children[childIdx].comments.push(newComment);
  n.children[childIdx].commentCount++;
  n.commentCount++;
  input.value = '';
  renderViewPanel();
  showToast('댓글이 등록되었습니다.', 'success');
}

function deleteComment(noticeId, childIdx, commentId) {
  const n = allNotices.find(x=>x.id===noticeId);
  if(!n) return;
  n.children[childIdx].comments = n.children[childIdx].comments.filter(c=>c.id!==commentId);
  n.children[childIdx].commentCount = Math.max(0, n.children[childIdx].commentCount-1);
  n.commentCount = Math.max(0, n.commentCount-1);
  renderViewPanel();
  showToast('댓글이 삭제되었습니다.');
}

function openWritePanelFromView() {
  closeViewPanel();
  openWritePanelEdit(currentViewId);
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

